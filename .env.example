# Quantitative Trad Backend environment template
# Copy this file to .env and replace all placeholder values.
# Never commit real .env files to GitHub.

QUANT_APP_NAME=Quantitative Trading System
QUANT_ENVIRONMENT=local
QUANT_TIMEZONE=Asia/Shanghai

# Database: sqlite for local quick start, mysql for production
QUANT_DATABASE_BACKEND=sqlite
QUANT_DATABASE_PATH=data/quant_system.db
# QUANT_DATABASE_URL=mysql+pymysql://quant:change_me@localhost:3306/quantitative_trad?charset=utf8mb4

# Trading safety
QUANT_TRADE_MODE=paper
QUANT_ALLOW_LIVE_TRADING=false
QUANT_ALLOW_MANUAL_OPEN=true
QUANT_ALLOW_MANUAL_CLOSE=true
QUANT_ALLOW_AUTO_BUY=false
QUANT_ALLOW_AUTO_CLOSE=true
QUANT_DEFAULT_CASH=1000000

# Paper trading cost model
QUANT_PAPER_BROKER_BACKEND=sqlite
QUANT_PAPER_SLIPPAGE_BPS=5.0
QUANT_PAPER_COMMISSION_RATE=0.0003
QUANT_PAPER_MIN_COMMISSION=5.0
QUANT_PAPER_STAMP_DUTY_RATE=0.001
QUANT_PAPER_TRANSFER_FEE_RATE=0.00001

# Cache
QUANT_REDIS_ENABLED=false
QUANT_REDIS_URL=redis://localhost:6379/0

# AI / LLM
QUANT_AI_ENABLED=true
QUANT_AI_MOCK_ENABLED=true
QUANT_AI_PROMPT_VERSION=v3
QUANT_AI_CONTEXT_KLINE_LIMIT=30
QUANT_AI_CONTEXT_NEWS_LIMIT=10
QUANT_AI_MAX_PROMPT_CHARS=24000
QUANT_AI_MAX_RAG_CONTEXT_CHARS=6000
QUANT_AI_MAX_RAG_CITATIONS=5
QUANT_LLM_PROVIDER=openai_compatible
QUANT_LLM_BASE_URL=
QUANT_LLM_API_KEY=
QUANT_LLM_MODEL=deepseek-chat
QUANT_LLM_TEMPERATURE=0.2
QUANT_LLM_TIMEOUT_SECONDS=30
QUANT_LLM_RETRY_COUNT=2
QUANT_LLM_RETRY_DELAY_SECONDS=1.0

# RAG / Qdrant / Embedding
QUANT_RAG_ENABLED=false
QUANT_RAG_VECTOR_BACKEND=qdrant
QUANT_RAG_QDRANT_URL=http://localhost:6333
QUANT_RAG_QDRANT_API_KEY=
QUANT_RAG_COLLECTION_NEWS=market_news_chunks
QUANT_RAG_EMBEDDING_PROVIDER=openai_compatible
QUANT_RAG_EMBEDDING_BASE_URL=
QUANT_RAG_EMBEDDING_API_KEY=
QUANT_RAG_EMBEDDING_MODEL=text-embedding-3-small
QUANT_RAG_EMBEDDING_DIMENSION=1536
QUANT_RAG_EMBEDDING_BATCH_SIZE=10
QUANT_RAG_EMBEDDING_RETRY_COUNT=2
QUANT_RAG_EMBEDDING_RETRY_DELAY_SECONDS=1.0
QUANT_RAG_CHUNK_SIZE=800
QUANT_RAG_CHUNK_OVERLAP=120
QUANT_RAG_SEARCH_LIMIT=8
QUANT_RAG_SCORE_THRESHOLD=
QUANT_RAG_SKIP_EMBEDDING_IF_PENDING_OVER=0
QUANT_RAG_NEWS_DAYS=14
